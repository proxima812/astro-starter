{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"strictNullChecks": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"exactOptionalPropertyTypes": true,
		"allowJs": true,
		"ignoreDeprecations": "6.0"
	},
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["node_modules", ".vercel", ".netlify", "dist"]
}
