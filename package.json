{
	"name": "proxima-starter",
	"type": "module",
	"version": "0.0.1",
	"bin": {
		"proxima-starter": "./bin/proxima-starter.mjs",
		"proxima": "./bin/proxima-starter.mjs"
	},
	"files": [
		"bin",
		"scaffold/package-template.json",
		"astro.config.mjs",
		"main.config.ts",
		"tsconfig.json",
		"public",
		"scripts/generate-favicons.mjs",
		"src",
		".gitignore",
		".vscode",
		".lighthouserc.json",
		"CHANGELOG.md",
		"README.md"
	],
	"scripts": {
		"predev": "bun scripts/generate-favicons.mjs",
		"dev": "astro dev",
		"generate:favicons": "bun scripts/generate-favicons.mjs",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check",
		"validate:seo": "node scripts/validate-seo.mjs",
		"check:seo": "bun run build && bun run validate:seo",
		"lighthouse": "bun run build && lhci autorun --config=.lighthouserc.json",
		"update:last-updated": "node scripts/update-last-updated.mjs",
		"smoke:cli": "bun scripts/smoke-cli.mjs",
		"pack:dry": "npm pack --dry-run",
		"release:check": "bun run check && bun run smoke:cli && bun run pack:dry",
		"release:dry": "bun scripts/release-dry.mjs",
		"release": "semantic-release",
		"version:patch": "npm version patch",
		"version:minor": "npm version minor",
		"version:major": "npm version major"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@astrojs/mdx": "5.0.4",
		"@astrojs/react": "5.0.4",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@astrojs/tailwind": "6.0.2",
		"@iconify-json/mdi": "^1.2.3",
		"@paper-design/shaders-react": "^0.0.43",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^12.0.2",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@tailwindcss/vite": "^4.2.4",
		"@toolwind/corner-shape": "^0.0.8-3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "6.1.9",
		"astro-icon": "^1.1.5",
		"astro-meta-tags": "^0.3.2",
		"astro-seo-schema": "^6.0.0",
		"clsx": "^2.1.1",
		"motion": "^12.38.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"schema-dts": "^2.0.0",
		"semantic-release": "^25.0.3",
		"split-type": "^0.3.4",
		"tailwind-merge": "^2.6.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@iconify-json/ri": "^1.2.10",
		"@iconify-json/tabler": "^1.2.33",
		"@lhci/cli": "^0.15.1",
		"@tailwindcss/typography": "^0.5.19"
	}
}
